# Backend (FastAPI) — all have working defaults for local dev; see
# backend/app/core/config.py. Copy the ones you need into backend/.env.
REMY_DATABASE_URL=sqlite:///./remy_review_studio.db
REMY_UPLOAD_DIR=./uploads
REMY_MAX_UPLOAD_SIZE_MB=50
REMY_CORS_ORIGINS=["http://localhost:3000"]

# Frontend (Next.js) — put this in frontend/.env.local.
NEXT_PUBLIC_API_URL=http://localhost:8000
